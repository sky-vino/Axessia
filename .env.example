# =============================================================================
# Axessia (Sky) — environment variable reference
# =============================================================================
# Copy to .env (root) for local dev. On Azure, set these in App Service
# Configuration → Application settings instead — do NOT commit this file.

# ── App basics ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ────────────────────────────────────────────────────────────────
# Local file (any relative or absolute path). On Azure use:
#   DATABASE_URL=sqlite:///home/data/accessibility.sqlite
DATABASE_URL=sqlite://data/accessibility.sqlite

# ── JWT secrets (generate with: openssl rand -base64 48) ─────────────────────
JWT_SECRET=<<<generate-a-64-char-random-string>>>
JWT_REFRESH_SECRET=<<<generate-a-different-64-char-random-string>>>

# ── Default admin user (seeded on first boot) ───────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@axessia.local
DEFAULT_ADMIN_PASSWORD=ChangeMe@123

# ── Azure OpenAI (required for the AI Fixes tab) ────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_DEPLOYMENT=<deployment-name>
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Scan queue ──────────────────────────────────────────────────────────────
# Use 'memory' for single-instance (local + single-container Azure).
# Use 'redis' + a REDIS_URL to spread scans across multiple instances.
SCAN_QUEUE_DRIVER=memory
SCAN_QUEUE_CONCURRENCY=2
# REDIS_URL=rediss://:<key>@<name>.redis.cache.windows.net:6380

# ── CORS / SPA ──────────────────────────────────────────────────────────────
# On Azure with same-origin serving, '*' is fine because every protected
# endpoint already requires a Bearer token. Restrict to your custom domain
# if/when you set one up.
FRONTEND_URL=*

# ── Frontend build (Vite) ───────────────────────────────────────────────────
# Leave unset to use the same origin's /api path; set if backend and
# frontend live on different hosts.
# VITE_API_URL=

# ── Static SPA path (only needed if you move frontend/dist) ─────────────────
# STATIC_DIR=/home/site/wwwroot/frontend/dist

# ── Playwright (Azure only) ─────────────────────────────────────────────────
# Where to install Chromium so it persists across App Service restarts.
# PLAYWRIGHT_BROWSERS_PATH=/home/playwright-browsers
